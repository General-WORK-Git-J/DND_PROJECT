{
    "configurations": [
        {
            "name": "C/C++: g++ debug (integrated terminal)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/DND_PROJECT",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "windows": {
                "program": "${workspaceFolder}\\DND_PROJECT.exe",
                "miDebuggerPath": "c:\\Program Files\\CodeBlocks\\MinGW\\bin\\gdb.exe",
                "externalConsole": true
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: g++ build active file"
        },
        {
            "name": "Run in Konsole (Linux only)",
            "type": "node-terminal",
            "request": "launch",
            "command": "konsole --hold -e '${workspaceFolder}/DND_PROJECT'",
            "preLaunchTask": "C/C++: g++ build active file"
        }
    ],
    "version": "2.0.0"
}
